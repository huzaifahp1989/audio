# Supabase Configuration
# Leave blank until you have real Supabase values. The app falls back safely in local/dev.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: For admin operations (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email Configuration (optional)
RESEND_API_KEY=your_resend_api_key
# Comma-separated inbox(es) for new chat alerts (huzaify786@gmail.com always included)
CHAT_ADMIN_EMAIL=huzaify786@gmail.com
# Optional custom sender (must be verified in Resend)
# CHAT_EMAIL_FROM=Kids Zone <noreply@yourdomain.com>
CRON_SECRET=your_cron_secret_for_scheduled_routes
REMINDER_TOKEN_SECRET=your_random_secret_for_unsubscribe_tokens

# Application Configuration
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_SITE_NAME=Islamic Kids Learning Platform

# Stripe (Kids Sadaqah online payments)
# Secret key: Stripe Dashboard → Developers → API keys (used by Next.js checkout + Supabase webhook function)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Production webhook URL (configure in Stripe Dashboard):
# https://jlqrbbqsuksncrxjcmbc.supabase.co/functions/v1/stripe-webhook
# Webhook signing secret: set as Supabase secret STRIPE_WEBHOOK_SECRET (see SETUP_STRIPE_WEBHOOK.md)
# Optional for local Next.js webhook only (`/api/stripe/webhook`):
# STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# OneSignal push notifications (App ID from OneSignal dashboard → Settings → Keys & IDs)
NEXT_PUBLIC_ONESIGNAL_APP_ID=0bb81263-a5f5-4fd8-8786-d71f43a43725
# MUST match the OneSignal App ID configured in WebToNative (native push).
ONESIGNAL_APP_ID=0bb81263-a5f5-4fd8-8786-d71f43a43725
# Browser/web push must use an OneSignal app with Web Push enabled (not the WTN mobile-only app).
NEXT_PUBLIC_ONESIGNAL_WEB_APP_ID=daf8fc36-781a-417d-8ee4-5078635f22e7
# Server-only REST API key from the SAME OneSignal app as ONESIGNAL_APP_ID
# (OneSignal dashboard → Settings → Keys & IDs → REST API Key). Required to SEND push.
ONESIGNAL_REST_API_KEY=
# Optional: old website OneSignal app so admin "All" still reaches prior web subscribers.
# Use the REST key from the WEB app (NEXT_PUBLIC_ONESIGNAL_WEB_APP_ID), not the mobile app.
ONESIGNAL_LEGACY_APP_ID=daf8fc36-781a-417d-8ee4-5078635f22e7
ONESIGNAL_LEGACY_REST_API_KEY=
# Separate iOS OneSignal app (Apple). If your iOS subscribers live in their own
# OneSignal app, set both so the server also delivers to iPhone/iPad users.
ONESIGNAL_IOS_APP_ID=
ONESIGNAL_IOS_REST_API_KEY=

# Cloudflare R2 file storage (images + recordings) — see SETUP_R2_STORAGE.md
# When set, new uploads skip Supabase Storage (cheaper; helps with quota).
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=kids-zone-media
# R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Google Analytics (optional)
# Set this to your GA4 measurement ID, for example G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-8LHGLLY2NC
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-8LHGLLY2NC

# Firebase Analytics (islam-media-stats) — public web client config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDIpe4_imqnRmn4hB5DadmzRGGl_AndpXc
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=islam-media-stats.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=islam-media-stats
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=islam-media-stats.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=748617367224
NEXT_PUBLIC_FIREBASE_APP_ID=1:748617367224:web:18469c9aa80e975860be4d
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-8LHGLLY2NC

# Ramadan mode: set to "force" to preview the Ramadan card outside Ramadan dates (remove in production after testing)
# NEXT_PUBLIC_RAMADAN_MODE=force
